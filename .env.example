# Machine A — copy to .env and fill in values

# Postgres (used by the API and River)
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://bttrlistings:changeme@postgres:5432/bttrlistings?sslmode=disable

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=changeme

# Machine B — Ollama GPU server
# Just run: ollama serve  (no Docker needed on Machine B)
# Make sure port 11434 is open on the network
OLLAMA_HOST=http://192.168.1.50:11434
OLLAMA_MODEL=gemma4:27b

# Comma-separated OLX search page URLs to scrape every 15 minutes
# Example: https://www.olx.pl/elektronika/komputery/,https://www.olx.pl/elektronika/telefony/
SCRAPER_URLS=

# HTTP port (default 8080)
PORT=8080

# Deal alerts — POST to this URL when deal_score >= 8 (optional)
# ntfy.sh example: https://ntfy.sh/your-topic-name
# Leave empty to disable alerts
ALERT_WEBHOOK_URL=
